{
  "$schema": "https://vega.github.io/schema/vega/v5.json",
  "title": "Iron Ore Trade Flow - Sankey Diagram",
  "description": "Global iron ore export flows with percentages and country filters",
  "width": 1200,
  "height": 700,
  "padding": {"left": 50, "right": 200, "top": 50, "bottom": 50},
  
  "data": [
    {
      "name": "trade_data",
      "url": "data/iron_ore_sankey_oec.csv",
      "format": {"type": "csv", "parse": {"value_usd_billion": "number"}}
    },
    {
      "name": "filtered_data",
      "source": "trade_data",
      "transform": [
        {
          "type": "filter",
          "expr": "(sourceFilter.length === 0 || indexof(sourceFilter, datum.source) >= 0) && (targetFilter.length === 0 || indexof(targetFilter, datum.target) >= 0)"
        }
      ]
    },
    {
      "name": "source_totals",
      "source": "filtered_data",
      "transform": [
        {"type": "aggregate", "groupby": ["source"], "ops": ["sum"], "fields": ["value_usd_billion"], "as": ["total"]},
        {"type": "joinaggregate", "ops": ["sum"], "fields": ["total"], "as": ["grand_total"]}
      ]
    },
    {
      "name": "target_totals",
      "source": "filtered_data",
      "transform": [
        {"type": "aggregate", "groupby": ["target"], "ops": ["sum"], "fields": ["value_usd_billion"], "as": ["total"]},
        {"type": "joinaggregate", "ops": ["sum"], "fields": ["total"], "as": ["grand_total"]}
      ]
    },
    {
      "name": "enriched_data",
      "source": "filtered_data",
      "transform": [
        {"type": "lookup", "from": "source_totals", "key": "source", "fields": ["source"], "values": ["total", "grand_total"], "as": ["src_total", "grand_total"]},
        {"type": "lookup", "from": "target_totals", "key": "target", "fields": ["target"], "values": ["total", "grand_total"], "as": ["tgt_total", "grand_total2"]},
        {
          "type": "formula",
          "expr": "datum.src_total ? (datum.value_usd_billion / datum.src_total * 100) : 0",
          "as": "pct_of_source"
        },
        {
          "type": "formula",
          "expr": "datum.tgt_total ? (datum.value_usd_billion / datum.tgt_total * 100) : 0",
          "as": "pct_of_target"
        }
      ]
    },
    {
      "name": "nodes",
      "source": "enriched_data",
      "transform": [
        {
          "type": "fold",
          "fields": ["source", "target"],
          "as": ["role", "id"]
        },
        {"type": "filter", "expr": "datum.id != null"},
        {"type": "aggregate", "groupby": ["id"]},
        {"type": "collect", "sort": {"field": "id"}}
      ]
    },
    {
      "name": "links",
      "source": "enriched_data",
      "transform": [
        {
          "type": "formula",
          "expr": "indexof(pluck(data('nodes'), 'id'), datum.source)",
          "as": "source_idx"
        },
        {
          "type": "formula",
          "expr": "indexof(pluck(data('nodes'), 'id'), datum.target)",
          "as": "target_idx"
        }
      ]
    },
    {
      "name": "sankey_graph",
      "source": "links",
      "transform": [
        {
          "type": "sankey",
          "node": {"groupby": ["id"]},
          "links": {"source": "source_idx", "target": "target_idx", "value": "value_usd_billion"}
        }
      ]
    }
  ],

  "signals": [
    {
      "name": "sourceFilter",
      "value": [],
      "bind": {
        "input": "select",
        "options": [[], ["Australia"], ["Brazil"], ["South Africa"], ["Canada"], ["India"], ["Sweden"]],
        "labels": ["All Sources", "Australia", "Brazil", "South Africa", "Canada", "India", "Sweden"],
        "name": "Filter Source: "
      }
    },
    {
      "name": "targetFilter",
      "value": [],
      "bind": {
        "input": "select",
        "options": [[], ["China"], ["Japan"], ["South Korea"], ["Germany"], ["Taiwan"], ["Malaysia"], ["Bahrain"], ["Netherlands"]],
        "labels": ["All Targets", "China", "Japan", "South Korea", "Germany", "Taiwan", "Malaysia", "Bahrain", "Netherlands"],
        "name": "Filter Target: "
      }
    }
  ],

  "marks": [
    {
      "type": "rect",
      "from": {"data": "sankey_graph"},
      "encode": {
        "enter": {
          "stroke": {"value": "#333"},
          "strokeWidth": {"value": 0.5}
        },
        "update": {
          "x": {"field": "x0"},
          "y": {"field": "y0"},
          "x2": {"field": "x1"},
          "y2": {"field": "y1"},
          "fill": {"scale": "color", "field": "index"},
          "fillOpacity": {"value": 0.8},
          "tooltip": {"signal": "datum.id"}
        },
        "hover": {"fillOpacity": {"value": 1}}
      }
    },
    {
      "type": "path",
      "from": {"data": "sankey_graph"},
      "encode": {
        "update": {
          "stroke": {"value": "#999"},
          "strokeOpacity": {"value": 0.4},
          "fill": {"value": "transparent"},
          "tooltip": {"signal": "datum.source.id + ' → ' + datum.target.id + ' | USD ' + format(datum.value, '.2f') + 'B'"}
        },
        "hover": {"strokeOpacity": {"value": 0.8}}
      },
      "transform": [
        {
          "type": "linkpath",
          "orient": "horizontal",
          "shape": "diagonal",
          "sourceX": {"expr": "datum.source.x1"},
          "sourceY": {"expr": "datum.source.y0 + (datum.source.y1 - datum.source.y0) / 2"},
          "targetX": {"expr": "datum.target.x0"},
          "targetY": {"expr": "datum.target.y0 + (datum.target.y1 - datum.target.y0) / 2"}
        }
      ]
    },
    {
      "type": "text",
      "from": {"data": "sankey_graph"},
      "encode": {
        "enter": {
          "text": {"field": "id"},
          "fontSize": {"value": 12},
          "fontWeight": {"value": "bold"},
          "fill": {"value": "#222"}
        },
        "update": {
          "x": {"signal": "datum.x0 < datum.x1 ? datum.x1 + 5 : datum.x0 - 5"},
          "y": {"signal": "datum.y0 + (datum.y1 - datum.y0) / 2"},
          "baseline": {"value": "middle"},
          "align": {"signal": "datum.x0 < datum.x1 ? 'left' : 'right'"}
        }
      }
    }
  ],

  "scales": [
    {"name": "color", "type": "ordinal", "scheme": "category20", "domain": {"data": "nodes", "field": "id"}}
  ]
}

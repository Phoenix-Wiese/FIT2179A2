{
	"$schema": "https://vega.github.io/schema/vega/v5.json",
	"description": "Treemap of iron ore production and iron content by country.",
	"width": 960,
	"height": 560,
	"padding": 8,
	"autosize": "pad",
	"title": {
		"text": "Iron Ore Production Treemap",
		"subtitle": "Area by iron_ore_prod, grouped by continent",
		"anchor": "start",
		"fontSize": 22,
		"subtitleFontSize": 13,
		"color": "#1f2937"
	},
	"data": [
		{
			"name": "tree",
			"values": [
				{ "id": "World", "parent": null, "value": 0 },

				{ "id": "Africa", "parent": "World", "value": 0 },
				{ "id": "Asia", "parent": "World", "value": 0 },
				{ "id": "Europe", "parent": "World", "value": 0 },
				{ "id": "North America", "parent": "World", "value": 0 },
				{ "id": "Oceania", "parent": "World", "value": 0 },
				{ "id": "South America", "parent": "World", "value": 0 },

				{ "id": "Australia", "parent": "Oceania", "value": 960, "iron_content": 584 },
				{ "id": "Brazil", "parent": "South America", "value": 440, "iron_content": 276 },
				{ "id": "China", "parent": "Asia", "value": 280, "iron_content": 170 },
				{ "id": "India", "parent": "Asia", "value": 270, "iron_content": 156 },
				{ "id": "Russia", "parent": "Europe", "value": 88, "iron_content": 55.8 },
				{ "id": "Iran", "parent": "Asia", "value": 77, "iron_content": 51.3 },
				{ "id": "Canada", "parent": "North America", "value": 70, "iron_content": 41.4 },
				{ "id": "South Africa", "parent": "Africa", "value": 61, "iron_content": 40.5 },
				{ "id": "Kazakhstan", "parent": "Asia", "value": 53, "iron_content": 8.9 },
				{ "id": "United States", "parent": "North America", "value": 44, "iron_content": 24.7 },
				{ "id": "Sweden", "parent": "Europe", "value": 38, "iron_content": 27.7 },
				{ "id": "Ukraine", "parent": "Europe", "value": 36, "iron_content": 21.3 },
				{ "id": "Peru", "parent": "South America", "value": 19, "iron_content": 12.9 },
				{ "id": "Chile", "parent": "South America", "value": 18, "iron_content": 11.1 },
				{ "id": "Turkey", "parent": "Asia", "value": 17, "iron_content": 10.7 },
				{ "id": "Mauritania", "parent": "Africa", "value": 13, "iron_content": 8 },
				{ "id": "Mexico", "parent": "North America", "value": 12, "iron_content": 6.8 }
			],
			"transform": [
				{
					"type": "stratify",
					"key": "id",
					"parentKey": "parent"
				},
				{
					"type": "treemap",
					"field": "value",
					"sort": { "field": "value", "order": "descending" },
					"method": "squarify",
					"paddingInner": 2,
					"paddingOuter": 4,
					"round": true,
					"size": [{ "signal": "width" }, { "signal": "height" }]
				}
			]
		},
		{
			"name": "countries",
			"source": "tree",
			"transform": [{ "type": "filter", "expr": "datum.depth === 2" }]
		},
		{
			"name": "continents",
			"source": "tree",
			"transform": [{ "type": "filter", "expr": "datum.depth === 1" }]
		}
	],
	"scales": [
		{
			"name": "color",
			"type": "ordinal",
			"domain": ["Africa", "Asia", "Europe", "North America", "Oceania", "South America"],
			"range": ["#9c6644", "#3b7d6b", "#457b9d", "#e76f51", "#588157", "#b56576"]
		}
	],
	"marks": [
		{
			"type": "rect",
			"from": { "data": "countries" },
			"encode": {
				"enter": {
					"stroke": { "value": "#f8fafc" },
					"strokeWidth": { "value": 1 }
				},
				"update": {
					"x": { "field": "x0" },
					"y": { "field": "y0" },
					"x2": { "field": "x1" },
					"y2": { "field": "y1" },
					"fill": { "scale": "color", "field": "parent" },
					"tooltip": {
						"signal": "{\"continent\": datum.parent, \"country\": datum.id, \"iron_ore_prod_Mt\": datum.value, \"iron_content_Mt\": datum.data && isValid(datum.data.iron_content) ? datum.data.iron_content : null}"
					}
				},
				"hover": {
					"stroke": { "value": "#0f172a" },
					"strokeWidth": { "value": 2 }
				}
			}
		},
		{
			"type": "text",
			"from": { "data": "countries" },
			"encode": {
				"update": {
					"x": { "signal": "(datum.x0 + datum.x1) / 2" },
					"y": { "signal": "(datum.y0 + datum.y1) / 2" },
					"text": {
						"signal": "(datum.x1 - datum.x0) > 80 && (datum.y1 - datum.y0) > 28 ? datum.id : ''"
					},
					"align": { "value": "center" },
					"baseline": { "value": "middle" },
					"fill": { "value": "white" },
					"fontWeight": { "value": "bold" },
					"fontSize": { "value": 12 }
				}
			}
		},
		{
			"type": "text",
			"from": { "data": "continents" },
			"encode": {
				"update": {
					"x": { "field": "x0", "offset": 6 },
					"y": { "field": "y0", "offset": 14 },
					"text": { "field": "id" },
					"fill": { "value": "#111827" },
					"fontSize": { "value": 12 },
					"fontWeight": { "value": "bold" }
				}
			}
		}
	]
}
